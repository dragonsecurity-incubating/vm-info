# vm-info auto-loads .env from the working directory on startup.
# Copy this file to .env and fill in the values you need; .env is gitignored.

# Default connection URI (used when --connect is omitted).
# VM_INFO_URI=pve://pve.example.com/?insecure=1

# Fallback libvirt URI if VM_INFO_URI is not set.
# LIBVIRT_DEFAULT_URI=qemu+ssh://user@hypervisor/system

# Proxmox VE API token: USER@REALM!TOKENID=SECRET
# Create one at Datacenter -> Permissions -> API Tokens.
# PVE_API_TOKEN=root@pam!vminfo=00000000-1111-2222-3333-444444444444

# Skip TLS verification for self-signed Proxmox certs (1 = insecure).
# PVE_INSECURE=1

# GitHub token for 'vm-info update' — only needed to dodge anonymous
# rate limits when checking the releases API.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
